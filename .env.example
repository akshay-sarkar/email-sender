# App password gate (protects the send-email form)
APP_PASSWORD=xxx_xxxx_xxxx_xxxx

# Gmail credentials
# Use an App Password (not your regular Gmail password):
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=xxx_xxxx_xxxx_xxxx
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Display name shown in the From field
SENDER_NAME=Your Name

# Server port (optional, defaults to 3001)
PORT=3001

# Google Drive attachments (public folder — shared as "Anyone with the link can view")
# Paste the full folder URL from your browser
GDRIVE_FOLDER_LINK=https://drive.google.com/drive/folders/YOUR_FOLDER_ID
# API key with Google Drive API v3 enabled
# console.cloud.google.com → APIs & Services → Credentials → Create API key
# Then enable: APIs & Services → Library → "Google Drive API"
GDRIVE_API_KEY=YOUR_GDRIVE_API_KEY
